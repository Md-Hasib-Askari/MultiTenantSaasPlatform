  "components": {
    "parameters": {
      "TenantIdHeader": {
        "name": "X-Tenant-Id",
        "in": "header",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "example": "0194fae2-2c84-7d93-bb89-8c1c9b3e8e3a",
        "description": "Tenant GUID returned from login response"
      },
      "AuthorizationHeader": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "schema": { "type": "string", "pattern": "^Bearer .+$" },
        "example": "Bearer {{token}}",
        "description": "JWT access token from login response"
      }
    },
    "schemas": {
      "AddProjectMemberDto": {
        "required": ["userId"],
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid",
            "example": "0194fae2-2c84-7d93-bb89-8c1c9b3e8e5c"
          }
        }
      },
      "CreateProjectDto": {
        "required": ["name", "description", "color"],
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "My Project" },
          "description": { "type": ["null", "string"], "example": "A sample project for testing" },
          "color": { "type": ["null", "string"], "example": "#63B3ED" }
        }
      },
      "CreateTaskDto": {
        "required": ["projectId", "title", "description"],
        "type": "object",
        "properties": {
          "projectId": { "type": "string", "format": "uuid", "example": "0194fae2-2c84-7d93-bb89-8c1c9b3e8e4b" },
          "title": { "type": "string", "example": "Implement login" },
          "description": { "type": ["null", "string"], "example": "Add JWT authentication flow" },
          "status": { "$ref": "#/components/schemas/TaskItemStatus", "example": "NotStarted" },
          "priority": { "oneOf": [{ "type": "null" }, { "$ref": "#/components/schemas/TaskPriority" }], "example": 2 },
          "assigneeId": { "type": ["null", "string"], "format": "uuid", "example": null },
          "reporterId": { "type": ["null", "string"], "format": "uuid", "example": null },
          "dueDate": { "type": ["null", "string"], "format": "date-time", "example": null },
          "estimatedHours": { "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$", "type": ["null", "number", "string"], "format": "double", "example": null },
          "sequence": { "pattern": "^-?(?:0|[1-9]\\d*)$", "type": ["integer", "string"], "format": "int32", "default": 0, "example": 0 }
        }
      },
      "CreateTenantDto": {
        "required": ["slug", "name"],
        "type": "object",
        "properties": {
          "slug": { "type": "string", "example": "acme" },
          "name": { "type": "string", "example": "Acme Corp" },
          "plan": { "$ref": "#/components/schemas/PlanTier", "example": 1 }
        }
      },
      "LoginRequest": {
        "required": ["email", "password"],
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "admin@mtsp.dev" },
          "password": { "type": "string", "example": "Admin123!" }
        }
      },
      "PlanTier": { "type": "integer", "example": 1 },
      "ProjectMemberRole": {
        "enum": ["Member", "Editor", "Admin"],
        "example": "Admin"
      },
      "RegisterRequest": {
        "required": ["email", "password", "displayName", "tenantSlug"],
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "test@mtsp.dev" },
          "password": { "type": "string", "example": "Passw0rd!" },
          "displayName": { "type": "string", "example": "Test User" },
          "tenantSlug": { "type": "string", "example": "acme" }
        }
      },
      "TaskItemStatus": {
        "enum": ["NotStarted", "InProgress", "Completed", "OnHold", "Cancelled", null],
        "example": "NotStarted"
      },
      "TaskPriority": { "type": "integer", "example": 2 },
      "TenantStatus": { "type": "integer", "example": 0 },
      "UpdateProjectDto": {
        "required": ["name", "description", "color"],
        "type": "object",
        "properties": {
          "name": { "type": ["null", "string"], "example": "Renamed Project" },
          "description": { "type": ["null", "string"], "example": "Updated description" },
          "color": { "type": ["null", "string"], "example": "#48BB78" }
        }
      },
      "UpdateProjectMemberRoleDto": {
        "required": ["role"],
        "type": "object",
        "properties": {
          "role": { "$ref": "#/components/schemas/ProjectMemberRole", "example": "Admin" }
        }
      },
      "UpdateTaskDto": {
        "required": ["title", "description", "status", "priority", "assigneeId", "reporterId", "dueDate", "estimatedHours", "sequence"],
        "type": "object",
        "properties": {
          "title": { "type": ["null", "string"], "example": "Implement login" },
          "description": { "type": ["null", "string"], "example": "Add JWT authentication flow" },
          "status": { "oneOf": [{ "type": "null" }, { "$ref": "#/components/schemas/TaskItemStatus" }], "example": "InProgress" },
          "priority": { "oneOf": [{ "type": "null" }, { "$ref": "#/components/schemas/TaskPriority" }], "example": 2 },
          "assigneeId": { "type": ["null", "string"], "format": "uuid", "example": null },
          "reporterId": { "type": ["null", "string"], "format": "uuid", "example": null },
          "dueDate": { "type": ["null", "string"], "format": "date-time", "example": "2026-07-15T00:00:00Z" },
          "estimatedHours": { "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$", "type": ["null", "number", "string"], "format": "double", "example": 8.0 },
          "sequence": { "pattern": "^-?(?:0|[1-9]\\d*)$", "type": ["null", "integer", "string"], "format": "int32", "example": 1 }
        }
      },
      "UpdateTenantDto": {
        "required": ["name", "tenantStatus", "tenantPlan", "billingEmail"],
        "type": "object",
        "properties": {
          "name": { "type": ["null", "string"], "example": "Acme Corp" },
          "tenantStatus": { "$ref": "#/components/schemas/TenantStatus", "example": 0 },
          "tenantPlan": { "$ref": "#/components/schemas/PlanTier", "example": 1 },
          "billingEmail": { "type": ["null", "string"], "example": "billing@acme.com" }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth" },
    { "name": "Project" },
    { "name": "ProjectMember" },
    { "name": "Task" },
    { "name": "Tenant" }
  ]
}
